APP_NAME="Discord Announce Bot"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── Settings Page ────────────────────────────────────────────────
# Contraseña para acceder a /settings (vacío = sin contraseña en dev)
SETTINGS_PASSWORD=

# ─── Sesión ───────────────────────────────────────────────────────
# En Vercel se sobreescribe a "cookie" automáticamente via vercel.json
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ─── Base de datos ────────────────────────────────────────────────
# Local: SQLite automático (no necesitas configurar nada más)
# Vercel: Configura DATABASE_URL en el dashboard de Vercel con tu Neon/Postgres URL
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ─── Discord Bot ──────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_GUILD_ID=
DISCORD_ANNOUNCEMENT_CHANNEL_ID=
DISCORD_FORTNITE_CHANNEL_ID=
DISCORD_ANNOUNCE_ROLE_ID=
DISCORD_FORTNITE_ROLE_ID=

# ─── Discord OAuth2 (para login en el panel web) ──────────────────
# DISCORD_CLIENT_SECRET: OAuth2 > General > Client Secret (Developer Portal)
# DISCORD_ADMIN_ID: tu Discord user ID (clic derecho → Copiar ID en Discord)
# Registrar redirect URI en Discord Developer Portal → OAuth2 → Redirects:
#   https://tu-proyecto.vercel.app/auth/discord/callback
DISCORD_CLIENT_SECRET=
DISCORD_ADMIN_ID=
