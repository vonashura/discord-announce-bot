APP_NAME="Discord Announce Bot"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── Settings Page ────────────────────────────────────────────────
# Contraseña para acceder a /settings (vacío = sin contraseña en dev)
SETTINGS_PASSWORD=

# ─── Sesión ───────────────────────────────────────────────────────
# En Vercel se sobreescribe a "cookie" automáticamente via vercel.json
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ─── Base de datos ────────────────────────────────────────────────
# Local: SQLite automático (no necesitas configurar nada más)
# Vercel: Configura DATABASE_URL en el dashboard de Vercel con tu Neon/Postgres URL
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ─── Discord (opcional aquí, configurable también desde /settings) ─
# Estos campos se pueden configurar desde la página web /settings
# pero también funcionan como fallback si se definen aquí
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_GUILD_ID=
DISCORD_ANNOUNCEMENT_CHANNEL_ID=
DISCORD_FORTNITE_CHANNEL_ID=
DISCORD_ANNOUNCE_ROLE_ID=
DISCORD_FORTNITE_ROLE_ID=
