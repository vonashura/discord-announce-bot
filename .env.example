APP_NAME="Discord Announce Bot"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── Discord Bot ──────────────────────────────────────────────────
# https://discord.com/developers/applications → tu app
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_APPLICATION_ID=your_application_id_here
DISCORD_PUBLIC_KEY=your_public_key_here

# Para comandos de gremio (se registran al instante, ideal para desarrollo)
# Dejar vacío para registrar comandos globales (puede tardar ~1 hora)
DISCORD_GUILD_ID=your_guild_id_here

# ─── Canales ──────────────────────────────────────────────────────
# IDs de los canales de Discord donde se enviarán los embeds
DISCORD_ANNOUNCEMENT_CHANNEL_ID=your_announcement_channel_id
DISCORD_FORTNITE_CHANNEL_ID=your_fortnite_channel_id

# ─── Roles (opcional) ─────────────────────────────────────────────
# El bot mencionará estos roles al enviar el embed
DISCORD_ANNOUNCE_ROLE_ID=
DISCORD_FORTNITE_ROLE_ID=
